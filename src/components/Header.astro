---
import siteData from '../data/site.json';
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">{siteData.name}</a>
    <nav>
      <a href="/">Home</a>
      <a href="/about">About</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
  }

  .site-logo:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }
</style>
