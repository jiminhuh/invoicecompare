---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import ToolCard from '../components/ToolCard.astro';
import siteData from '../data/site.json';
import tools from '../data/tools.json';

const title = `${siteData.name} — ${siteData.description}`;
const description = siteData.description;
const toolCount = tools.length;
const currentMonth = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": siteData.name,
  "description": siteData.description,
  "numberOfItems": tools.length,
  "itemListElement": tools.map((tool, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": tool.name,
    "url": `${siteData.domain}/${tool.slug}`,
  })),
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <section class="hero">
    <h1>{siteData.name}</h1>
    <p class="hero-sub">{siteData.description}</p>
    <div class="trust-badges">
      <span class="badge">Updated {currentMonth}</span>
      <span class="badge-sep"></span>
      <span class="badge">{toolCount} tool{toolCount !== 1 ? 's' : ''} compared</span>
      <span class="badge-sep"></span>
      <span class="badge">Independently reviewed</span>
    </div>
  </section>

  <section class="overview">
    <div class="section-header">
      <h2>Quick Comparison</h2>
      <p class="section-sub">See how all tools stack up at a glance.</p>
    </div>
    <ComparisonTable tools={tools} />
  </section>

  <section class="tools-grid">
    <div class="section-header">
      <h2>Detailed Overview</h2>
      <p class="section-sub">In-depth look at each tool with pros, cons, and our recommendation.</p>
    </div>
    <div class="grid">
      {tools.map((tool) => (
        <ToolCard
          name={tool.name}
          slug={tool.slug}
          description={tool.description}
          summary={tool.summary}
          website={tool.website}
          rating={tool.rating}
          pros={tool.pros}
          cons={tool.cons}
          affiliate_url={tool.affiliate_url}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero h1 {
    margin-top: 0;
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-text), var(--color-text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0.25rem auto 1.25rem;
    line-height: 1.6;
  }

  .trust-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .badge {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .badge-sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  .section-header {
    margin-bottom: 0.5rem;
  }

  .section-header h2 {
    margin-bottom: 0.2rem;
    position: relative;
    display: inline-block;
  }

  .section-header h2::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), #6366f1);
    border-radius: 2px;
    margin-top: 0.3rem;
  }

  .section-sub {
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .overview {
    margin-top: 2.5rem;
  }

  .tools-grid {
    margin-top: 3.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 1.85rem;
    }

    .hero-sub {
      font-size: 1.05rem;
    }
  }
</style>
