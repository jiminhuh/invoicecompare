---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import ToolCard from '../components/ToolCard.astro';
import siteData from '../data/site.json';
import tools from '../data/tools.json';

const title = `${siteData.name} — ${siteData.description}`;
const description = siteData.description;

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": siteData.name,
  "description": siteData.description,
  "numberOfItems": tools.length,
  "itemListElement": tools.map((tool, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": tool.name,
    "url": `${siteData.domain}/${tool.slug}`,
  })),
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <section class="hero">
    <h1>{siteData.name}</h1>
    <p class="hero-sub">{siteData.description}</p>
    <p class="updated">Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
  </section>

  <section class="overview">
    <h2>Quick Comparison</h2>
    <ComparisonTable tools={tools} />
  </section>

  <section class="tools-grid">
    <h2>Detailed Overview</h2>
    <div class="grid">
      {tools.map((tool) => (
        <ToolCard
          name={tool.name}
          slug={tool.slug}
          description={tool.description}
          rating={tool.rating}
          pros={tool.pros}
          cons={tool.cons}
          affiliate_url={tool.affiliate_url}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 2rem 0 1.5rem;
  }

  .hero h1 {
    margin-top: 0;
    font-size: 2.25rem;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto 0.5rem;
  }

  .updated {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .overview {
    margin-top: 2rem;
  }

  .tools-grid {
    margin-top: 3rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 1.75rem;
    }
  }
</style>
